# Archivo de ejemplo para variables de entorno
# Copia este archivo a .env y rellena con tus valores reales

# Clave secreta de Flask (protege sesiones y cookies)
SECRET_KEY=tu_clave_secreta_aqui
# TTL de tokens de restablecimiento de contraseña en segundos (default: 1800 = 30 min)
# PASSWORD_RESET_TOKEN_EXPIRATION_SECONDS=1800

# Configuración de Flask
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_APP=run.py

############################
# CONFIGURACIÓN DE MONGODB
############################
# URI de conexión a MongoDB Atlas
MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/nombre_db?retryWrites=true&w=majority

############################
# CONFIGURACIÓN DE CORREO (BREVO/SMTP)
############################
MAIL_SERVER=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USE_TLS=True
EMAIL_USER=tu_usuario_smtp
EMAIL_PASS=tu_password_smtp
MAIL_DEFAULT_SENDER=noreply@tudominio.com
CONTACT_MAIL_RECIPIENT=admin@tudominio.com

############################
# CONFIGURACIÓN DE AWS S3 (Opcional)
###########################
AWS_ACCESS_KEY_ID=tu_aws_key_id
AWS_SECRET_ACCESS_KEY=tu_aws_secret_key
AWS_REGION=eu-central-1
S3_BUCKET_NAME=tu_bucket_name
USE_S3=false

############################
# API KEYS & OTROS
############################
GEMINI_API_KEY=tu_gemini_api_key
BREVO_API_KEY=tu_brevo_api_key
PYTHONPATH=.
